<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex,nofollow">
  <title>{{ business_name }} - Website Opportunity Card</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #17202a;
      --muted: #5d6b7a;
      --line: #d8e0e8;
      --soft: #f5f8fb;
      --accent: #0f766e;
      --warn: #b45309;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--ink);
      background: #ffffff;
      line-height: 1.45;
    }
    main { max-width: 1120px; margin: 0 auto; padding: 32px 18px; }
    header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 20px;
      align-items: end;
      border-bottom: 1px solid var(--line);
      padding-bottom: 20px;
      margin-bottom: 22px;
    }
    h1 { margin: 0 0 8px; font-size: clamp(30px, 5vw, 54px); line-height: 1; }
    h2 { margin: 0 0 12px; font-size: 20px; }
    h3 { margin: 0 0 8px; font-size: 16px; }
    p { margin: 0 0 12px; }
    a { color: var(--accent); }
    .pill {
      display: inline-block;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 7px 11px;
      color: var(--muted);
      font-size: 13px;
      margin: 3px 6px 3px 0;
      background: var(--soft);
    }
    .score {
      text-align: right;
      min-width: 130px;
    }
    .score strong {
      display: block;
      font-size: 46px;
      line-height: 1;
      color: var(--accent);
    }
    .grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 18px; }
    .panel {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 18px;
      background: #ffffff;
    }
    .shots { display: grid; grid-template-columns: 1fr 0.45fr; gap: 14px; align-items: start; }
    .shot img {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 6px;
      display: block;
      background: var(--soft);
    }
    .shot span { display: block; color: var(--muted); font-size: 12px; margin-top: 6px; }
    ul { margin: 0; padding-left: 20px; }
    li { margin: 0 0 8px; }
    .metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 12px; }
    .metric {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 12px;
      background: var(--soft);
    }
    .metric b { display: block; font-size: 26px; }
    .metric small { display: block; color: var(--muted); margin-top: 4px; }
    .cta {
      margin-top: 18px;
      padding: 16px;
      border: 1px solid #99f6e4;
      border-radius: 8px;
      background: #f0fdfa;
    }
    footer {
      margin-top: 24px;
      padding-top: 16px;
      border-top: 1px solid var(--line);
      color: var(--muted);
      font-size: 12px;
    }
    @media (max-width: 860px) {
      header, .grid, .shots { grid-template-columns: 1fr; }
      .score { text-align: left; }
      .metrics { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main>
    <header>
      <div>
        <h1>{{ business_name }}</h1>
        <p>{{ city }} {{ niche_label }} website opportunity review</p>
        <span class="pill">{{ next_action }}</span>
        <span class="pill">Review Priority: {{ expected_close_score }}/100</span>
        {% if website_url %}<span class="pill">{{ website_url }}</span>{% endif %}
      </div>
      <div class="score">
        <strong>{{ expected_close_score }}</strong>
        <span>review priority score</span>
      </div>
    </header>

    <section class="grid">
      <div class="panel">
        <h2>Current Website Snapshots</h2>
        <div class="shots">
          <div class="shot">
            {% if desktop_screenshot_src %}
            <img src="{{ desktop_screenshot_src }}" alt="{{ business_name }} desktop screenshot">
            {% else %}
            <p>No desktop screenshot captured yet.</p>
            {% endif %}
            <span>Desktop capture</span>
          </div>
          <div class="shot">
            {% if mobile_screenshot_src %}
            <img src="{{ mobile_screenshot_src }}" alt="{{ business_name }} mobile screenshot">
            {% else %}
            <p>No mobile screenshot captured yet.</p>
            {% endif %}
            <span>Mobile capture</span>
          </div>
        </div>
      </div>

      <aside class="panel">
        <h2>Quick Signals</h2>
        <div class="metrics">
          <div class="metric">
            <span>Mobile</span>
            <b>{{ mobile_pagespeed_score }}</b>
            <small>{{ mobile_pagespeed_source }}</small>
          </div>
          <div class="metric">
            <span>Desktop</span>
            <b>{{ desktop_pagespeed_score }}</b>
            <small>{{ desktop_pagespeed_source }}</small>
          </div>
          <div class="metric">
            <span>Action</span>
            <b>{{ next_action_short }}</b>
          </div>
        </div>
        <div class="cta">
          <h3>Suggested angle</h3>
          <p>{{ sales_angle }}</p>
        </div>
      </aside>
    </section>

    <section class="grid" style="margin-top:18px;">
      <div class="panel">
        <h2>Top Website Issues</h2>
        <ul>
          {% for issue in top_issues %}
          <li>{{ issue }}</li>
          {% endfor %}
        </ul>
      </div>
      <div class="panel">
        <h2>Recommended Improvements</h2>
        <ul>
          {% for improvement in recommended_improvements %}
          <li>{{ improvement }}</li>
          {% endfor %}
        </ul>
      </div>
    </section>

    <section class="panel" style="margin-top:18px;">
      <h2>Call To Action</h2>
      <p>A focused human review can confirm whether the screenshots, mobile speed, trust presentation, and conversion flow justify an outreach offer.</p>
      {% if phone_display %}
      <p><strong>Primary phone:</strong> <a href="tel:{{ phone_tel }}">{{ phone_display }}</a></p>
      {% endif %}
    </section>

    <footer>
      Private concept draft for discussion. Not affiliated with or published by the business.
    </footer>
  </main>
</body>
</html>

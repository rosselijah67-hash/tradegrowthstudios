# Copy this file to .env and fill in local-only secrets.

# SQLite
DATABASE_PATH=data/leads.db

# Production dashboard login. For local dev, leave DASHBOARD_AUTH_ENABLED blank
# unless you want to test the login gate.
DASHBOARD_AUTH_ENABLED=
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD_HASH=
FLASK_SECRET_KEY=
# Temporary production DB import page. Set true only while uploading a DB,
# then set false and redeploy.
DASHBOARD_DB_IMPORT_ENABLED=

# Railway persistent volume. Mount the Railway volume at /app/storage and set
# USE_STORAGE_SYMLINKS=1 so data/runs/artifacts/screenshots/public_outreach/backups persist.
USE_STORAGE_SYMLINKS=
STORAGE_ROOT=/app/storage

# Logging
LOG_LEVEL=INFO

# Google Places Text Search (New)
GOOGLE_MAPS_API_KEY=

# Optional PageSpeed Insights API key. The API can run without a key, but a key
# gives you clearer quota ownership.
PAGESPEED_API_KEY=

# Optional public/local base URL for generated artifacts.
# Example: https://example.com/private-drafts
ARTIFACT_BASE_URL=

# SMTP settings for send_outreach.py. Real sending requires --send,
# physical address, and unsubscribe email. Without --send, only planned sends are logged.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
OUTREACH_FROM_EMAIL=
OUTREACH_FROM_NAME=Local Growth Audit
OUTREACH_BUSINESS_NAME=
OUTREACH_PHYSICAL_ADDRESS=
OUTREACH_UNSUBSCRIBE_EMAIL=
OUTREACH_REPLY_TO_EMAIL=
PUBLIC_PACKET_BASE_URL=

# Polite crawler identity for future HTTP-based audit steps.
USER_AGENT=ai-local-site-leads/0.1 (+local batch pipeline)
